	task.spawn(function()
		local lastHadBrainrot = nil
		while true do
			task.wait(0.2)
			if not _G.AutoSemiInvisEnabled then
				-- Si se apagó el toggle y el invis sigue activo, apagarlo
				if _G.invisibleStealEnabled then
					pcall(_G.toggleInvisibleSteal)
					updateVisualState(false)
				end
				lastHadBrainrot = nil
				continue
			end
			-- Solo usar Stealing — es la fuente más confiable
			local hasBrainrot = (LocalPlayer:GetAttribute("Stealing") == true)

			-- Siempre forzar apagado si no hay brainrot, sin esperar cambio de estado
			if not hasBrainrot and _G.invisibleStealEnabled then
				pcall(_G.toggleInvisibleSteal)
				updateVisualState(false)
				lastHadBrainrot = false
				continue
			end

			if lastHadBrainrot == hasBrainrot then continue end
			lastHadBrainrot = hasBrainrot

			if hasBrainrot and not _G.invisibleStealEnabled then
				pcall(_G.toggleInvisibleSteal)
				updateVisualState(true)
			end
		end
	end)

